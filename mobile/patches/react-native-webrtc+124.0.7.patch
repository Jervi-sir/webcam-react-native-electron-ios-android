+- (void)focusAtPoint:(CGPoint)point error:(NSError **)outError {
+    if (!self.device) {
+        if (outError) {
+            *outError = [NSError
+                errorWithDomain:@"react-native-webrtc"
+                           code:0
+                       userInfo:@{NSLocalizedDescriptionKey : @"Camera device is not ready for focus."}];
+        }
+        return;
+    }
+
+    NSError *lockError = nil;
+    if (![self.device lockForConfiguration:&lockError]) {
+        if (outError) {
+            *outError = lockError;
+        }
+        return;
+    }
+
+    CGPoint normalizedPoint =
+        CGPointMake(clampNormalizedValue(point.x), clampNormalizedValue(point.y));
+
+    if (self.device.isFocusPointOfInterestSupported) {
+        self.device.focusPointOfInterest = normalizedPoint;
+    }
+
+    if ([self.device isFocusModeSupported:AVCaptureFocusModeAutoFocus]) {
+        self.device.focusMode = AVCaptureFocusModeAutoFocus;
+    } else if ([self.device isFocusModeSupported:AVCaptureFocusModeContinuousAutoFocus]) {
+        self.device.focusMode = AVCaptureFocusModeContinuousAutoFocus;
+    }
+
+    if (self.device.isExposurePointOfInterestSupported) {
+        self.device.exposurePointOfInterest = normalizedPoint;
+    }
+
+    if ([self.device isExposureModeSupported:AVCaptureExposureModeContinuousAutoExposure]) {
+        self.device.exposureMode = AVCaptureExposureModeContinuousAutoExposure;
+    }
+
+    [self.device unlockForConfiguration];
+}
+
+- (void)setZoomLevel:(CGFloat)zoomLevel error:(NSError **)outError {
+    if (!self.device) {
+        if (outError) {
+            *outError = [NSError
+                errorWithDomain:@"react-native-webrtc"
+                           code:0
+                       userInfo:@{NSLocalizedDescriptionKey : @"Camera device is not ready for zoom."}];
+        }
+        return;
+    }
+
+    NSError *lockError = nil;
+    if (![self.device lockForConfiguration:&lockError]) {
+        if (outError) {
+            *outError = lockError;
+        }
+        return;
+    }
+
+    CGFloat minZoom = self.device.minAvailableVideoZoomFactor;
+    CGFloat maxZoom = self.device.maxAvailableVideoZoomFactor;
+    CGFloat requested = MAX(zoomLevel, 1.0);
+    CGFloat clampedZoom = MIN(MAX(requested, minZoom), maxZoom);
+    self.device.videoZoomFactor = clampedZoom;
+
+    [self.device unlockForConfiguration];
+}
