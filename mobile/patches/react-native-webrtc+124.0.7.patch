+RCT_EXPORT_METHOD(mediaStreamTrackFocusAtPoint : (nonnull NSString *)trackID x : (nonnull NSNumber *)x y
+                      : (nonnull NSNumber *)y resolver : (RCTPromiseResolveBlock)resolve rejecter
+                      : (RCTPromiseRejectBlock)reject) {
+#if TARGET_OS_TV
+    reject(@"unsupported_platform", @"tvOS is not supported", nil);
+    return;
+#else
+    RTCMediaStreamTrack *track = self.localTracks[trackID];
+    if (track == nil) {
+        reject(@"E_INVALID", @"Could not get track", nil);
+        return;
+    }
+
+    if (![track.kind isEqualToString:@"video"]) {
+        reject(@"E_INVALID", @"Can't focus on audio tracks", nil);
+        return;
+    }
+
+    RTCVideoTrack *videoTrack = (RTCVideoTrack *)track;
+    if (![videoTrack.captureController isKindOfClass:[VideoCaptureController class]]) {
+        reject(@"E_INVALID", @"Video track does not support tap-to-focus", nil);
+        return;
+    }
+
+    VideoCaptureController *vcc = (VideoCaptureController *)videoTrack.captureController;
+    NSError *error = nil;
+    [vcc focusAtPoint:CGPointMake([x floatValue], [y floatValue]) error:&error];
+    if (error) {
+        reject(@"E_INVALID", error.localizedDescription, error);
+        return;
+    }
+
+    resolve(nil);
+#endif
+}
+
+RCT_EXPORT_METHOD(mediaStreamTrackSetZoom : (nonnull NSString *)trackID zoom : (nonnull NSNumber *)zoom resolver
+                      : (RCTPromiseResolveBlock)resolve rejecter : (RCTPromiseRejectBlock)reject) {
+#if TARGET_OS_TV
+    reject(@"unsupported_platform", @"tvOS is not supported", nil);
+    return;
+#else
+    RTCMediaStreamTrack *track = self.localTracks[trackID];
+    if (track == nil) {
+        reject(@"E_INVALID", @"Could not get track", nil);
+        return;
+    }
+
+    if (![track.kind isEqualToString:@"video"]) {
+        reject(@"E_INVALID", @"Can't set zoom on audio tracks", nil);
+        return;
+    }
+
+    RTCVideoTrack *videoTrack = (RTCVideoTrack *)track;
+    if (![videoTrack.captureController isKindOfClass:[VideoCaptureController class]]) {
+        reject(@"E_INVALID", @"Video track does not support zoom", nil);
+        return;
+    }
+
+    VideoCaptureController *vcc = (VideoCaptureController *)videoTrack.captureController;
+    NSError *error = nil;
+    [vcc setZoomLevel:[zoom floatValue] error:&error];
+    if (error) {
+        reject(@"E_INVALID", error.localizedDescription, error);
+        return;
+    }
+
+    resolve(nil);
+#endif
+}
